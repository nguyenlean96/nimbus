{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "watchAssets": true,
    "assets": [
      "**/*.js",
      "**/*.json"
    ]
  },
  "watchOptions": {
    "watchExclude": [
      "client/**/*"
    ]
  }
}
